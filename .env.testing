APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
CACHE_STORE=array

MAIL_MAILER=array

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

PULSE_ENABLED=false
